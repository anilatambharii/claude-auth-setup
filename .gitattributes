# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF (Unix line endings)
*.sh text eol=lf

# Batch files should always use CRLF (Windows line endings)
*.bat text eol=crlf
*.cmd text eol=crlf

# Documentation should use LF
*.md text eol=lf
*.txt text eol=lf
LICENSE text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary
